using System;

using System.ComponentModel.DataAnnotations.Schema;

namespace OOD_Project2026_maxbatrak.Models
{
    public class ItineraryItem : TripItem
    {
        // Foreign key back to Trip
        public int TripId { get; set; }
        public TimeSpan Time { get; set; }
        public ItineraryItemType ItemType { get; set; }
        public TimeSpan? EndTime { get; set; }

        public ItineraryItem()
            : base(string.Empty, DateTime.Today)
        {
        }

        public ItineraryItem(string title, DateTime date, TimeSpan time, ItineraryItemType itemType)
            : base(title, date)
        {
            Time = time;
            ItemType = itemType;
        }

        [NotMapped]
        public override string Summary
        {
            get
            {
                string timeText = DateTime.Today.Add(Time).ToString("hh:mm tt");
                return $"{timeText} – {Title} ({ItemType})";
            }
        }

        [NotMapped]
        public string TimeDisplay
        {
            get { return DateTime.Today.Add(Time).ToString("hh:mm tt"); }
        }
    }
}
