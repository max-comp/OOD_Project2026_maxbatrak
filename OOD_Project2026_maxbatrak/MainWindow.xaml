<Window x:Class="OOD_Project2026_maxbatrak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOD_Project2026_maxbatrak"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="1000"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.Resources>

        <!-- DataTemplate: how each Trip appears in the Trips ListBox -->
        <DataTemplate x:Key="TripItemTemplate">
            <StackPanel Margin="2,4">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Text="{Binding Destination}" Foreground="Gray" FontSize="11" />
                <TextBlock FontSize="11" Foreground="#888">
                    <Run Text="{Binding StartDate, StringFormat=MMM dd yyyy}" />
                    <Run Text=" – " />
                    <Run Text="{Binding EndDate, StringFormat=MMM dd yyyy}" />
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- DataTemplate: how each Expense row appears in the Expenses ListView -->
        <DataTemplate x:Key="ExpenseRowTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Title}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Category}" VerticalAlignment="Center" />
                <!-- Amount is green when paid, red when owed -->
                <TextBlock Grid.Column="2" Text="{Binding AmountDisplay}" VerticalAlignment="Center"
                           Foreground="{Binding IsPaid, Converter={x:Static local:BoolToBrushConverter.Instance}}" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{Binding PaidDisplay}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" />
            </Grid>
        </DataTemplate>

        <!-- DataTemplate: how each Booking row appears in the Bookings ListView -->
        <DataTemplate x:Key="BookingRowTemplate">
            <StackPanel Orientation="Horizontal">
                <Border Background="#E3F2FD" CornerRadius="3" Padding="4,1" Margin="0,0,8,0">
                    <TextBlock Text="{Binding BookingType}" FontSize="11" Foreground="#1565C0" />
                </Border>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DateDisplay}" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <TabControl x:Name="MainTabs" TabStripPlacement="Bottom">
        <TabItem x:Name="HomeTab" Header="Home">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="174*" />
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Main Menu" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />

                <Grid Grid.Row="1" Margin="0,16,0,0" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Trips List" Margin="0,0,8,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Bottom" Content="Add Trip" Margin="8" Click="AddTrip_Click" />
                            <TextBox x:Name="TripSearchBox" DockPanel.Dock="Top" Margin="8,8,8,0"
                                     materialDesign:HintAssist.Hint="Search trips…"
                                     TextChanged="TripSearchBox_TextChanged" />
                            <ListBox x:Name="TripsListBox" Margin="8"
                                     ItemTemplate="{StaticResource TripItemTemplate}"
                                     SelectionChanged="TripsListBox_SelectionChanged" />
                        </DockPanel>
                    </GroupBox>

                    <Border Grid.Column="1" Margin="8,0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <!-- Shown when no trip is selected -->
                            <StackPanel x:Name="WelcomePanel" Margin="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Welcome!" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="Select or create a trip to get started." Margin="0,8,0,0" HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Shown when a trip with a destination is selected -->
                            <StackPanel x:Name="CountryPanel" Visibility="Collapsed" Margin="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="FlagImage" Width="120" Height="80" Stretch="Uniform" Margin="0,0,0,12" />
                                <TextBlock x:Name="CountryNameText" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock x:Name="CountryCapitalText" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="Gray" />
                                <TextBlock x:Name="CountryCurrencyText" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="Gray" />
                                <TextBlock x:Name="CountryRegionText" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="Gray" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <GroupBox Grid.Column="2" Header="Trip Summary" Margin="8,0,0,0">
                        <StackPanel Margin="8">
                            <TextBlock x:Name="SummaryPlaceholder" Text="Select a trip to see details" FontStyle="Italic" Foreground="Gray" />

                            <StackPanel x:Name="SummaryPanel" Visibility="Collapsed">
                                <TextBlock x:Name="SummaryName" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock x:Name="SummaryDates" Margin="0,6,0,0" />

                                <Separator Margin="0,10" />

                                <TextBlock Text="Itinerary Items" FontWeight="SemiBold" />
                                <TextBlock x:Name="SummaryItineraryCount" Margin="0,2,0,8" />

                                <TextBlock Text="Bookings" FontWeight="SemiBold" />
                                <TextBlock x:Name="SummaryBookingsCount" Margin="0,2,0,8" />

                                <Separator Margin="0,6" />

                                <TextBlock Text="Budget" FontWeight="SemiBold" />
                                <TextBlock x:Name="SummaryTotal" Margin="0,2,0,0" />
                                <TextBlock x:Name="SummaryPaid" Margin="0,2,0,0" Foreground="Green" />
                                <TextBlock x:Name="SummaryOwed" Margin="0,2,0,0" Foreground="OrangeRed" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem x:Name="ItineraryTab" Header="Itinerary">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Itinerary View" FontSize="22" FontWeight="SemiBold" />

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Days List" Margin="0,0,8,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Bottom" Content="Add Item" Margin="8" Click="AddItineraryItem_Click" />
                            <ListBox x:Name="DaysListBox" Margin="8" DisplayMemberPath="" SelectionChanged="DaysListBox_SelectionChanged" />
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Items List" Margin="8,0">
                        <ListView x:Name="ItineraryListView" Margin="8" SelectionChanged="ItineraryListView_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="80" DisplayMemberBinding="{Binding TimeDisplay}" />
                                    <GridViewColumn Header="Title" Width="140" DisplayMemberBinding="{Binding Title}" />
                                    <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding ItemType}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Add / Edit" Margin="8,0,0,0">
                        <StackPanel Margin="8">
                            <TextBlock Text="Title" />
                            <TextBox x:Name="ItineraryTitleBox" Margin="0,4,0,8" />

                            <TextBlock Text="Type" />
                            <ComboBox x:Name="ItineraryTypeCombo" Margin="0,4,0,8">
                                <ComboBoxItem Content="Flight" />
                                <ComboBoxItem Content="Activity" />
                                <ComboBoxItem Content="Restaurant" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>

                            <TextBlock Text="Date" />
                            <DatePicker x:Name="ItineraryDatePicker" Margin="0,4,0,8" />

                            <TextBlock Text="Time (HH:mm)" />
                            <TextBox x:Name="ItineraryTimeBox" Margin="0,4,0,12" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Save" Margin="0,0,8,0" Click="SaveItineraryItem_Click" />
                                <Button Content="Cancel" Click="CancelItineraryItem_Click" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem x:Name="BookingsTab" Header="Bookings">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Bookings View" FontSize="22" FontWeight="SemiBold" />

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Booking List" Margin="0,0,8,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Bottom" Content="Add Booking" Margin="8" Click="AddBooking_Click" />
                            <TextBox x:Name="BookingSearchBox" DockPanel.Dock="Top" Margin="8,8,8,0"
                                     materialDesign:HintAssist.Hint="Search bookings…"
                                     TextChanged="BookingSearchBox_TextChanged" />
                            <ListView x:Name="BookingsListView" Margin="8"
                                      ItemTemplate="{StaticResource BookingRowTemplate}"
                                      SelectionChanged="BookingsListView_SelectionChanged" />
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Add / Edit" Margin="8,0,0,0">
                        <StackPanel Margin="8">
                            <TextBlock Text="Reference" />
                            <TextBox x:Name="BookingReferenceBox" Margin="0,4,0,8" />

                            <TextBlock Text="Type" />
                            <ComboBox x:Name="BookingTypeCombo" Margin="0,4,0,8">
                                <ComboBoxItem Content="Flight" />
                                <ComboBoxItem Content="Hotel" />
                                <ComboBoxItem Content="Transport" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>

                            <TextBlock Text="Check-in / Depart" />
                            <DatePicker x:Name="BookingDatePicker" Margin="0,4,0,8" />

                            <TextBlock Text="From" />
                            <TextBox x:Name="BookingFromBox" Margin="0,4,0,8" />

                            <TextBlock Text="To" />
                            <TextBox x:Name="BookingToBox" Margin="0,4,0,12" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Save" Margin="0,0,8,0" Click="SaveBooking_Click" />
                                <Button Content="Cancel" Click="CancelBooking_Click" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem x:Name="BudgetTab" Header="Budget">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Budget View" FontSize="22" FontWeight="SemiBold" />

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Expenses List" Margin="0,0,8,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Bottom" Content="Add Expense" Margin="8" Click="AddExpense_Click" />
                            <TextBox x:Name="ExpenseSearchBox" DockPanel.Dock="Top" Margin="8,8,8,0"
                                     materialDesign:HintAssist.Hint="Search expenses…"
                                     TextChanged="ExpenseSearchBox_TextChanged" />
                            <ListView x:Name="ExpensesListView" Margin="8"
                                      ItemTemplate="{StaticResource ExpenseRowTemplate}"
                                      SelectionChanged="ExpensesListView_SelectionChanged" />
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Add / Edit" Margin="8,0,0,0">
                        <StackPanel Margin="8">
                            <TextBlock Text="Category" />
                            <ComboBox x:Name="ExpenseCategoryCombo" Margin="0,4,0,8">
                                <ComboBoxItem Content="Dining" />
                                <ComboBoxItem Content="Transport" />
                                <ComboBoxItem Content="Lodging" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>

                            <TextBlock Text="Title" />
                            <TextBox x:Name="ExpenseTitleBox" Margin="0,4,0,8" />

                            <TextBlock Text="Amount" />
                            <TextBox x:Name="ExpenseAmountBox" Margin="0,4,0,8" />

                            <TextBlock Text="Paid" />
                            <ComboBox x:Name="ExpensePaidCombo" Margin="0,4,0,12">
                                <ComboBoxItem Content="Yes" />
                                <ComboBoxItem Content="No" />
                            </ComboBox>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Save" Margin="0,0,8,0" Click="SaveExpense_Click" />
                                <Button Content="Cancel" Click="CancelExpense_Click" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
